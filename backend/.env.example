# ── OpenRouter LLM ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-4-maverick

# ── Kie.ai Image Generation (Nano Banana 2) ──────────────────────────
KIE_API_KEY=your-kie-api-key-here

# ── MuseTalk Lip-Sync Video (optional) ─────────────────────────────
# Set to true if you have a powerful GPU (RTX 4090+) for real-time lip-sync.
# On RTX 3060 this is ~15x slower than real-time — not recommended.
MUSETALK_ENABLED=false
MUSETALK_URL=http://localhost:8001
