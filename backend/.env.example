# ── OpenRouter LLM ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-4-maverick

# ── Kie.ai Image Generation (Nano Banana 2) ──────────────────────────
KIE_API_KEY=your-kie-api-key-here

# ── Deepgram STT + TTS (recommended — enables voice input via LiveKit) ──
# Free $200 credit at https://console.deepgram.com/signup (no CC required)
DEEPGRAM_API_KEY=your-deepgram-key-here

# ── TTS Provider (text-to-speech) ─────────────────────────────────────
# Options: edge (free, default), cartesia (fast), elevenlabs (quality), deepgram (cheap)
TTS_PROVIDER=edge
# CARTESIA_API_KEY=your-cartesia-key     # Required for cartesia provider
# ELEVENLABS_API_KEY=your-elevenlabs-key # Required for elevenlabs provider

# ── Video Call / MuseTalk Lip-Sync (optional) ─────────────────────────
# Set to true ONLY if you have a high-VRAM GPU (RTX 4090/5090, 16+ GB VRAM).
# Run `python check_gpu.py` to auto-detect your GPU and get a recommendation.
# When false: audio + text only (CSS speaking animations). Works on any hardware.
USE_VIDEO_CALL=false
MUSETALK_URL=http://localhost:8001

# ── LiveKit WebRTC (optional, for real-time A/V) ─────────────────────
# Install: pip install livekit livekit-api
# Server: docker run -d -p 7880:7880 -p 7881:7881 -p 7882:7882/udp livekit/livekit-server --dev
# Or use LiveKit Cloud: https://cloud.livekit.io
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
